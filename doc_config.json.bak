{
    "coverage_settings": {
        "tracked_modules": [
            ["src", "Source Code", 10],
            ["tests", "Tests", 5],
            [".know", "Knowledge Infrastructure", 8]
        ],
        "thresholds": {
            "density": 50.0,
            "complexity": 10
        }
    },
    "artifacts": {
        "README.md": {
            "description": "General documentation and project overview.",
            "depends_on": ["src/", "tests/"]
        },
        "AGENTS.md": {
            "description": "Instructions and context for AI agents.",
            "depends_on": [".know/knowledge/", ".know/doc_config.json"]
        }
    },
    "knowledge_items": {},
    "knowledge_system": {
        "mcp_server": {
            "name": "KnowledgeManager",
            "version": "1.0.0",
            "jail_dir": ".know"
        },
        "tools": [
            {
                "name": "audit_coverage",
                "description": "Run knowledge base coverage audit. Returns coverage matrix and recommendations.",
                "script": ".know/scripts/audit_coverage.py",
                "args": []
            },
            {
                "name": "sync_agents_md",
                "description": "Synchronize AGENTS.md with current KI state.",
                "script": ".know/scripts/sync_agents_md.py",
                "args": []
            },
            {
                "name": "generate_dir_index",
                "description": "Generate or update DIR_INDEX.md.",
                "script": ".know/scripts/generate_dir_index.py",
                "args": []
            },
            {
                "name": "check_changes",
                "description": "Check changes in tracked project files.",
                "method": "check_changes",
                "args": []
            },
            {
                "name": "save_state",
                "description": "Commit current hash state (doc_state.json).",
                "method": "save_state",
                "args": []
            },
            {
                "name": "read_know_file",
                "description": "Read file inside .know.",
                "method": "read_file",
                "args": [
                    {"name": "rel_path", "type": "string", "description": "Path relative to .know/"}
                ]
            },
            {
                "name": "write_know_file",
                "description": "Safely create or overwrite file inside .know.",
                "method": "write_file",
                "args": [
                    {"name": "rel_path", "type": "string", "description": "Path relative to .know/"},
                    {"name": "content", "type": "string", "description": "File content"}
                ]
            },
            {
                "name": "edit_know_file",
                "description": "Safely edit file inside .know via text replacement.",
                "method": "edit_file",
                "args": [
                    {"name": "rel_path", "type": "string", "description": "Path relative to .know/"},
                    {"name": "old_text", "type": "string", "description": "Text to replace (must be unique)"},
                    {"name": "new_text", "type": "string", "description": "New text"}
                ]
            },
            {
                "name": "make_know_dir",
                "description": "Create new directory inside .know.",
                "method": "make_dir",
                "args": [
                    {"name": "rel_path", "type": "string", "description": "Path relative to .know/"}
                ]
            },
            {
                "name": "analyze_module",
                "description": "Analyze directory stats with knowledge coverage context.",
                "script": ".know/scripts/analyze_module.py",
                "args": [
                    {"name": "path", "type": "string", "description": "Path to analyze"},
                    {"name": "recursive", "type": "boolean", "description": "Depth of analysis"}
                ]
            },
            {
                "name": "analyze_dependencies",
                "description": "Analyze and update 'Related KIs' sections based on code imports.",
                "method": "analyze_dependencies",
                "args": [
                    {"name": "ki_name", "type": "string", "description": "Specific KI file to analyze (optional)"},
                    {"name": "only_changed", "type": "boolean", "description": "Analyze only modified Files/KIs (optional)"}
                ]
            }
        ]
    }
}
